{
  "name": "policyforge-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Baxter Growth Lab - AI insurance growth, local SEO, scripting, and sales enablement engine",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack && node scripts/copy-pdfkit-data.cjs",
    "build:cloudways": "next build --webpack && node scripts/copy-pdfkit-data.cjs && node scripts/sync-next-static.cjs",
    "start": "next start",
    "start:cloudways": "node start-policyforge-lab.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "reset-password": "node scripts/reset-user-password.cjs"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.8.2",
    "clsx": "^2.1.1",
    "jsonrepair": "^3.14.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "pdfkit": "^0.19.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "prettier": "^3.5.0",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
