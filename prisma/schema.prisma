generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceSubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  INACTIVE
  CANCELED
}

enum StoryIdeaStatus {
  UNUSED
  SAVED
  IN_PROGRESS
  DRAFTED
  PRODUCED
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum StoryProjectStatus {
  DOSSIER
  OUTLINE
  DRAFTING
  CRITIQUE
  REWRITE
  FINAL
  PRODUCED
  PUBLISHED
  ARCHIVED
}

enum StoryProjectFormat {
  STANDALONE
  EPISODIC_SERIES
  PODCAST_EPISODE
  ARTICLE
  SHORT_BOOK
  LONG_BOOK
}

enum ScriptPassType {
  INTRO
  DOSSIER
  ANALYTICS_BRIEF
  EPISODES
  SERIES_BIBLE
  HOOK_LAB
  STORY_SPINE
  STRUCTURE
  RETENTION_MAP
  SCRIPT_LENGTH_GOVERNOR
  OPEN_LOOP_LEDGER
  DRAFT
  RETENTION_ANALYSIS
  CRITIQUE
  FACT_CHECK
  REWRITE
  VOICE_POLISH
  QUALITY_GATE
  FINAL
  OUTRO
  SCENE_CARDS
  PUBLISHING_PACK
}

enum GenerationStatus {
  SUCCESS
  FAILED
}

enum AutomationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum TrendOpportunityStatus {
  OPEN
  SELECTED
  DEVELOPED
  DISMISSED
  COMPLETED
}

enum SeasonStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum CalendarOpportunityRelevance {
  RELEVANT
  POSSIBLE
  IRRELEVANT
}

enum PublishingSlotType {
  STANDALONE
  EPISODE
}

enum PublishingSlotStatus {
  SCHEDULED
  PRODUCED
  PUBLISHED
  SKIPPED
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String?                 @unique
  emailVerified          DateTime?
  image                  String?
  passwordHash           String?                 @db.Text
  role                   UserRole                @default(USER)
  disabledAt             DateTime?
  activeWorkspaceId      String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  sessions               Session[]
  settings               UserSettings?
  activeWorkspace        Workspace?              @relation("UserActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  workspaceMemberships   WorkspaceMembership[]
  workspaceInvitesSent   WorkspaceInvite[]       @relation("WorkspaceInvitesSent")
  channels               Channel[]
  ideas                  StoryIdea[]
  projects               StoryProject[]
  youtubeConnections     YoutubeConnection[]
  youtubeSyncRuns        YoutubeSyncRun[]
  youtubeVideoMetrics    YoutubeVideoMetric[]
  youtubeRecommendations YoutubeRecommendation[]
  publishingSlots        PublishingSlot[]
  conversionCampaigns    ConversionCampaign[]
  conversionLeads        ConversionLead[]
  conversionEvents       ConversionEvent[]
  generationLogs         GenerationLog[]
  auditLogs              AuditLog[]
  canonicalSubjects      CanonicalSubject[]
  trendOpportunities     TrendOpportunity[]
  seasons                ContentSeason[]
  shortAssets            ShortAsset[]
  editorialOpportunities EditorialOpportunity[]
  automationJobs         AutomationJob[]

  @@index([activeWorkspaceId])
}

model Workspace {
  id                     String                      @id @default(cuid())
  name                   String
  slug                   String                      @unique
  tagline                String                      @default("Texas Insurance Growth Engine")
  logoUrl                String?                     @db.Text
  customDomain           String?                     @unique
  subscriptionStatus     WorkspaceSubscriptionStatus @default(ACTIVE)
  subscriptionPlan       String?                     @db.Text
  setupCompletedAt       DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  activeUsers            User[]                      @relation("UserActiveWorkspace")
  memberships            WorkspaceMembership[]
  invites                WorkspaceInvite[]
  channels               Channel[]
  ideas                  StoryIdea[]
  projects               StoryProject[]
  youtubeConnections     YoutubeConnection[]
  youtubeSyncRuns        YoutubeSyncRun[]
  youtubeVideoMetrics    YoutubeVideoMetric[]
  youtubeRecommendations YoutubeRecommendation[]
  publishingSlots        PublishingSlot[]
  conversionCampaigns    ConversionCampaign[]
  conversionLeads        ConversionLead[]
  conversionEvents       ConversionEvent[]
  generationLogs         GenerationLog[]
  auditLogs              AuditLog[]
  canonicalSubjects      CanonicalSubject[]
  trendOpportunities     TrendOpportunity[]
  seasons                ContentSeason[]
  shortAssets            ShortAsset[]
  editorialOpportunities EditorialOpportunity[]
  automationJobs         AutomationJob[]

  @@index([subscriptionStatus])
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id              String        @id @default(cuid())
  workspaceId     String
  email           String
  role            WorkspaceRole @default(MEMBER)
  token           String        @unique
  invitedByUserId String
  acceptedAt      DateTime?
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy       User          @relation("WorkspaceInvitesSent", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

model Channel {
  id                      String                  @id @default(cuid())
  userId                  String
  workspaceId             String?
  name                    String
  slug                    String
  description             String?                 @db.Text
  archivedAt              DateTime?
  sourceFoundation        Json?
  sourceFoundationBuiltAt DateTime?
  shaziStyle              Json?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace               Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ideas                   StoryIdea[]
  projects                StoryProject[]
  youtubeConnection       YoutubeConnection?
  youtubeVideoMetrics     YoutubeVideoMetric[]
  youtubeRecommendations  YoutubeRecommendation[]
  conversionCampaigns     ConversionCampaign[]
  conversionLeads         ConversionLead[]
  conversionEvents        ConversionEvent[]
  canonicalSubjects       CanonicalSubject[]
  trendOpportunities      TrendOpportunity[]
  seasons                 ContentSeason[]
  shortAssets             ShortAsset[]
  editorialOpportunities  EditorialOpportunity[]
  automationJobs          AutomationJob[]

  @@unique([workspaceId, slug])
  @@index([userId])
  @@index([workspaceId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id                           String   @id @default(cuid())
  userId                       String   @unique
  openRouterApiKeyEncrypted    String?  @db.Text
  anthropicApiKeyEncrypted     String?  @db.Text
  openAiApiKeyEncrypted        String?  @db.Text
  defaultModel                 String   @default("anthropic/claude-sonnet-5")
  discoveryModel               String   @default("anthropic/claude-sonnet-5")
  dossierModel                 String   @default("anthropic/claude-sonnet-5")
  structureModel               String   @default("anthropic/claude-sonnet-5")
  draftingModel                String   @default("anthropic/claude-sonnet-5")
  critiqueModel                String   @default("openai/gpt-5.6-luna")
  rewriteModel                 String   @default("anthropic/claude-sonnet-5")
  anthropicModel               String   @default("claude-opus-4-8")
  openAiModel                  String   @default("gpt-5.6-luna")
  runwareApiKeyEncrypted       String?  @db.Text
  runwareModel                 String   @default("ideogram:4@0")
  dataForSeoLoginEncrypted     String?  @db.Text
  dataForSeoPasswordEncrypted  String?  @db.Text
  wordpressSiteUrl             String?  @db.Text
  wordpressUsernameEncrypted   String?  @db.Text
  wordpressPasswordEncrypted   String?  @db.Text
  youtubeClientId              String?  @db.Text
  youtubeClientSecretEncrypted String?  @db.Text
  thumbnailStyleGuide          String?  @db.Text
  workspaceName                String   @default("Baxter Growth Lab")
  workspaceTagline             String   @default("Texas Insurance Growth Engine")
  workspaceLogoUrl             String?  @db.Text
  defaultSponsorCta            String?  @db.Text
  publishingScheduleNote       String   @default("Mondays and Thursdays; one monthly Monday-Friday episode week.")
  autoModelRouting             Boolean  @default(true)
  preferredTone                String   @default("Mysterious & gripping")
  narrationStyle               String   @default("Calm suspense")
  defaultLengthMinutes         Int      @default(8)
  defaultCategories            Json?
  ttsPauseMarkers              Boolean  @default(false)
  alwaysFinishScripts          Boolean  @default(false)
  monthlyRunBudgetUsd          Decimal  @default(75) @db.Decimal(12, 2)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  user                         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StoryIdea {
  id                        String            @id @default(cuid())
  userId                    String
  workspaceId               String?
  channelId                 String?
  title                     String
  slug                      String
  hook                      String            @db.Text
  summary                   String            @db.Text
  category                  String
  sourceType                String?
  sourceUrls                Json?
  people                    Json?
  location                  String?
  eventDate                 DateTime?
  eventName                 String?
  originalityScore          Int               @default(0)
  curiosityScore            Int               @default(0)
  emotionalScore            Int               @default(0)
  escalationScore           Int               @default(0)
  lengthPotentialScore      Int               @default(0)
  researchDifficultyScore   Int               @default(0)
  estimatedLengthPotential  String?
  recommendedLengthMinutes  Int?
  episodeFit                String?
  bestFormat                String?
  episodeWhy                String?           @db.Text
  episodeArc                Json?
  episodeBusinessValue      String?           @db.Text
  recommendedTone           String?
  recommendedNarrationStyle String?
  totalScore                Int               @default(0)
  productionPriority        String            @default("Medium")
  suggestedAngle            String            @db.Text
  status                    StoryIdeaStatus   @default(UNUSED)
  usedAt                    DateTime?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  user                      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace                 Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel                   Channel?          @relation(fields: [channelId], references: [id], onDelete: SetNull)
  projects                  StoryProject[]
  trendOpportunity          TrendOpportunity?
  seasons                   ContentSeason[]

  @@index([userId, status])
  @@index([userId, channelId, status])
  @@index([userId, channelId, slug])
  @@index([userId, totalScore])
  @@index([workspaceId, status])
  @@index([workspaceId, channelId, status])
  @@index([workspaceId, channelId, slug])
  @@index([workspaceId, totalScore])
  @@index([title])
}

model StoryProject {
  id                   String              @id @default(cuid())
  userId               String
  workspaceId          String?
  channelId            String?
  storyIdeaId          String?
  canonicalSubjectId   String?
  seasonEpisodeId      String?             @unique
  title                String
  format               StoryProjectFormat  @default(STANDALONE)
  targetLengthMinutes  Int                 @default(8)
  targetWordCount      Int                 @default(1240)
  tone                 String              @default("Mysterious & gripping")
  narrationStyle       String              @default("Calm suspense")
  sourceMaterial       String?             @db.LongText
  sponsorBlurb         String?             @db.Text
  sponsorLink          String?             @db.Text
  youtubeVideoId       String?             @unique
  youtubeUploadStatus  String?
  youtubePrivacyStatus String?
  youtubeScheduledAt   DateTime?
  status               StoryProjectStatus  @default(DOSSIER)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel              Channel?            @relation(fields: [channelId], references: [id], onDelete: SetNull)
  storyIdea            StoryIdea?          @relation(fields: [storyIdeaId], references: [id], onDelete: SetNull)
  canonicalSubject     CanonicalSubject?   @relation(fields: [canonicalSubjectId], references: [id], onDelete: SetNull)
  seasonEpisode        SeasonEpisode?      @relation(fields: [seasonEpisodeId], references: [id], onDelete: SetNull)
  dossier              StoryDossier?
  outline              StoryOutline?
  drafts               ScriptDraft[]
  thumbnails           ThumbnailAsset[]
  publishingSlots      PublishingSlot[]
  publishedStories     PublishedStory[]
  generationLogs       GenerationLog[]
  conversionCampaign   ConversionCampaign?
  conversionLeads      ConversionLead[]
  conversionEvents     ConversionEvent[]
  shortAssets          ShortAsset[]
  automationJobs       AutomationJob[]

  @@unique([userId, channelId, storyIdeaId, format])
  @@unique([workspaceId, channelId, storyIdeaId, format])
  @@index([userId, status])
  @@index([userId, channelId, status])
  @@index([workspaceId, status])
  @@index([workspaceId, channelId, status])
  @@index([storyIdeaId])
  @@index([canonicalSubjectId])
  @@index([seasonEpisodeId])
}

model ThumbnailAsset {
  id             String       @id @default(cuid())
  storyProjectId String
  scriptDraftId  String?
  variant        Int
  title          String?      @db.Text
  prompt         String       @db.Text
  imageUrl       String       @db.Text
  imageUUID      String?
  taskUUID       String?
  modelUsed      String
  estimatedCost  Decimal      @default(0) @db.Decimal(12, 6)
  createdAt      DateTime     @default(now())
  storyProject   StoryProject @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)

  @@index([storyProjectId, createdAt])
  @@index([scriptDraftId])
}

model PublishingSlot {
  id              String               @id @default(cuid())
  userId          String
  workspaceId     String?
  channelId       String?
  storyProjectId  String
  title           String
  scheduledDate   DateTime
  slotType        PublishingSlotType   @default(STANDALONE)
  status          PublishingSlotStatus @default(SCHEDULED)
  episodeNumber   Int?
  episodeCount    Int?
  durationMinutes Int                  @default(7)
  batchId         String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  storyProject    StoryProject         @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId, scheduledDate])
  @@unique([workspaceId, channelId, scheduledDate])
  @@index([userId, scheduledDate])
  @@index([userId, channelId, scheduledDate])
  @@index([workspaceId, scheduledDate])
  @@index([workspaceId, channelId, scheduledDate])
  @@index([storyProjectId])
  @@index([batchId])
}

model StoryDossier {
  id                  String       @id @default(cuid())
  storyProjectId      String       @unique
  facts               Json
  timeline            Json
  characters          Json
  locations           Json
  unansweredQuestions Json
  sourceNotes         Json
  riskNotes           Json
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  storyProject        StoryProject @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)
}

model StoryOutline {
  id             String       @id @default(cuid())
  storyProjectId String       @unique
  hook           String       @db.Text
  actOne         Json
  actTwo         Json
  actThree       Json
  revealOrder    Json
  curiosityGaps  Json
  emotionalMap   Json
  retentionBeats Json
  ending         String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  storyProject   StoryProject @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)
}

model ScriptDraft {
  id               String         @id @default(cuid())
  storyProjectId   String
  version          Int
  modelUsed        String
  passType         ScriptPassType
  content          String         @db.LongText
  wordCount        Int            @default(0)
  estimatedMinutes Int            @default(0)
  createdAt        DateTime       @default(now())
  storyProject     StoryProject   @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)

  @@unique([storyProjectId, version, passType])
  @@index([storyProjectId, passType])
}

model PublishedStory {
  id             String       @id @default(cuid())
  storyProjectId String
  platform       String
  publishedUrl   String?      @db.Text
  publishedAt    DateTime
  notes          String?      @db.Text
  youtubeVideoId String?      @unique
  createdAt      DateTime     @default(now())
  storyProject   StoryProject @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)

  @@index([storyProjectId])
  @@index([publishedAt])
}

model ConversionCampaign {
  id             String            @id @default(cuid())
  userId         String
  workspaceId    String
  channelId      String
  storyProjectId String            @unique
  name           String
  slug           String            @unique
  publicToken    String            @unique
  destinationUrl String?           @db.Text
  cta            String            @db.Text
  phone          String            @default("281-445-1381")
  status         String            @default("ACTIVE")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel        Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  storyProject   StoryProject      @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)
  leads          ConversionLead[]
  events         ConversionEvent[]

  @@index([workspaceId, createdAt])
  @@index([channelId, createdAt])
  @@index([status])
}

model ConversionLead {
  id             String             @id @default(cuid())
  userId         String
  workspaceId    String
  channelId      String
  storyProjectId String
  campaignId     String
  name           String?
  email          String?
  phone          String?
  zipCode        String?
  product        String?
  message        String?            @db.Text
  status         String             @default("NEW")
  quotedPremium  Decimal?           @db.Decimal(12, 2)
  boundPremium   Decimal?           @db.Decimal(12, 2)
  notes          String?            @db.Text
  source         String             @default("youtube")
  medium         String             @default("video")
  content        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel        Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  storyProject   StoryProject       @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)
  campaign       ConversionCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  events         ConversionEvent[]

  @@index([workspaceId, status, createdAt])
  @@index([channelId, createdAt])
  @@index([storyProjectId])
  @@index([campaignId])
}

model ConversionEvent {
  id             String             @id @default(cuid())
  userId         String
  workspaceId    String
  channelId      String
  storyProjectId String
  campaignId     String
  leadId         String?
  eventType      String
  visitorId      String?
  referrer       String?            @db.Text
  userAgent      String?            @db.Text
  metadata       Json?
  createdAt      DateTime           @default(now())
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel        Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  storyProject   StoryProject       @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)
  campaign       ConversionCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead           ConversionLead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId, eventType, createdAt])
  @@index([campaignId, createdAt])
  @@index([storyProjectId, createdAt])
  @@index([leadId])
}

model YoutubeConnection {
  id                    String                  @id @default(cuid())
  userId                String
  workspaceId           String?
  channelId             String                  @unique
  youtubeChannelId      String
  youtubeChannelTitle   String
  accessTokenEncrypted  String?                 @db.Text
  refreshTokenEncrypted String?                 @db.Text
  tokenExpiresAt        DateTime?
  scopes                String?                 @db.Text
  lastSyncedAt          DateTime?
  nextSyncAt            DateTime?
  syncEnabled           Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace             Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel               Channel                 @relation(fields: [channelId], references: [id], onDelete: Cascade)
  syncRuns              YoutubeSyncRun[]
  videoMetrics          YoutubeVideoMetric[]
  recommendations       YoutubeRecommendation[]

  @@index([userId])
  @@index([workspaceId])
  @@index([youtubeChannelId])
  @@index([nextSyncAt])
}

model YoutubeVideoMetric {
  id                      String            @id @default(cuid())
  userId                  String
  workspaceId             String?
  channelId               String?
  youtubeConnectionId     String
  youtubeVideoId          String
  title                   String            @db.Text
  publishedAt             DateTime?
  thumbnailUrl            String?           @db.Text
  periodStart             DateTime
  periodEnd               DateTime
  views                   Int               @default(0)
  estimatedMinutesWatched Int               @default(0)
  averageViewDuration     Int               @default(0)
  averageViewPercentage   Float             @default(0)
  likes                   Int               @default(0)
  comments                Int               @default(0)
  shares                  Int               @default(0)
  subscribersGained       Int               @default(0)
  subscribersLost         Int               @default(0)
  impressions             Int               @default(0)
  impressionCtr           Float             @default(0)
  cardImpressions         Int               @default(0)
  cardClicks              Int               @default(0)
  cardClickRate           Float             @default(0)
  trafficSources          Json?
  searchTerms             Json?
  retentionCurve          Json?
  rawMetrics              Json?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace               Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel                 Channel?          @relation(fields: [channelId], references: [id], onDelete: SetNull)
  youtubeConnection       YoutubeConnection @relation(fields: [youtubeConnectionId], references: [id], onDelete: Cascade)

  @@unique([youtubeConnectionId, youtubeVideoId, periodStart, periodEnd])
  @@index([userId, periodEnd])
  @@index([workspaceId, periodEnd])
  @@index([channelId, periodEnd])
  @@index([youtubeVideoId])
}

model YoutubeSyncRun {
  id                  String            @id @default(cuid())
  userId              String
  workspaceId         String?
  youtubeConnectionId String
  status              String
  startedAt           DateTime          @default(now())
  finishedAt          DateTime?
  periodStart         DateTime?
  periodEnd           DateTime?
  videosSynced        Int               @default(0)
  recommendationCount Int               @default(0)
  errorMessage        String?           @db.Text
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace           Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  youtubeConnection   YoutubeConnection @relation(fields: [youtubeConnectionId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([workspaceId, startedAt])
  @@index([youtubeConnectionId, startedAt])
  @@index([status])
}

model YoutubeRecommendation {
  id                  String            @id @default(cuid())
  userId              String
  workspaceId         String?
  channelId           String?
  youtubeConnectionId String
  syncRunId           String?
  category            String
  priority            String
  title               String            @db.Text
  insight             String            @db.Text
  recommendation      String            @db.Text
  evidence            Json?
  status              String            @default("OPEN")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace           Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel             Channel?          @relation(fields: [channelId], references: [id], onDelete: SetNull)
  youtubeConnection   YoutubeConnection @relation(fields: [youtubeConnectionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([channelId, createdAt])
  @@index([youtubeConnectionId, createdAt])
  @@index([status])
}

model GenerationLog {
  id               String           @id @default(cuid())
  userId           String
  workspaceId      String?
  storyProjectId   String?
  passType         ScriptPassType?
  modelUsed        String
  promptTokens     Int              @default(0)
  completionTokens Int              @default(0)
  totalTokens      Int              @default(0)
  estimatedCost    Decimal          @default(0) @db.Decimal(12, 6)
  status           GenerationStatus
  errorMessage     String?          @db.Text
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  storyProject     StoryProject?    @relation(fields: [storyProjectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([storyProjectId])
}

model AuditLog {
  id          String     @id @default(cuid())
  userId      String?
  workspaceId String?
  action      String
  metadata    Json?
  ipHash      String?
  createdAt   DateTime   @default(now())
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([action])
}

model CanonicalSubject {
  id                     String         @id @default(cuid())
  userId                 String
  workspaceId            String
  channelId              String
  subjectKey             String
  canonicalName          String
  aliases                Json?
  verifiedSources        Json?
  approvedClaims         Json?
  quotations             Json?
  classifications        Json?
  evidence               Json?
  processedSourceUrls    Json?
  sourceFingerprint      String?
  noProgressCount        Int            @default(0)
  searchStrategy         String         @default("authoritative-first")
  researchLeaseProjectId String?
  researchLeaseUntil     DateTime?
  extractionCost         Decimal        @default(0) @db.Decimal(12, 6)
  verifiedAt             DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  user                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace              Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel                Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  projects               StoryProject[]

  @@unique([workspaceId, channelId, subjectKey])
  @@index([userId, channelId])
  @@index([workspaceId, canonicalName])
  @@index([researchLeaseUntil])
}

model TrendOpportunity {
  id              String                 @id @default(cuid())
  userId          String
  workspaceId     String
  channelId       String
  storyIdeaId     String?                @unique
  eventKey        String
  subject         String
  headline        String
  summary         String                 @db.Text
  sourceUrls      Json?
  score           Int
  relevanceReason String                 @db.Text
  suggestedAngle  String                 @db.Text
  riskLevel       String                 @default("LOW")
  status          TrendOpportunityStatus @default(OPEN)
  selectedAt      DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel         Channel                @relation(fields: [channelId], references: [id], onDelete: Cascade)
  storyIdea       StoryIdea?             @relation(fields: [storyIdeaId], references: [id], onDelete: SetNull)
  seasons         ContentSeason[]

  @@unique([workspaceId, channelId, eventKey])
  @@index([workspaceId, channelId, status, score])
  @@index([userId, createdAt])
}

model ContentSeason {
  id                 String            @id @default(cuid())
  userId             String
  workspaceId        String
  channelId          String
  storyIdeaId        String?
  trendOpportunityId String?
  title              String
  premise            String            @db.Text
  continuityRules    Json?
  status             SeasonStatus      @default(PLANNING)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace          Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel            Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  storyIdea          StoryIdea?        @relation(fields: [storyIdeaId], references: [id], onDelete: SetNull)
  trendOpportunity   TrendOpportunity? @relation(fields: [trendOpportunityId], references: [id], onDelete: SetNull)
  episodes           SeasonEpisode[]

  @@index([workspaceId, channelId, status])
  @@index([storyIdeaId])
  @@index([trendOpportunityId])
}

model SeasonEpisode {
  id                    String        @id @default(cuid())
  seasonId              String
  episodeNumber         Int
  title                 String
  hook                  String        @db.Text
  promise               String        @db.Text
  deltaResearchQuestion String?       @db.Text
  scheduledAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  season                ContentSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  project               StoryProject?

  @@unique([seasonId, episodeNumber])
  @@index([scheduledAt])
}

model ShortAsset {
  id             String       @id @default(cuid())
  userId         String
  workspaceId    String
  channelId      String
  storyProjectId String
  shortIndex     Int
  hook           String       @db.Text
  payoff         String       @db.Text
  script         String       @db.Text
  title          String
  caption        String       @db.Text
  sourceSafety   String       @db.Text
  exportAssets   Json?
  status         String       @default("DRAFT")
  scheduledAt    DateTime?
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel        Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  storyProject   StoryProject @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)

  @@unique([storyProjectId, shortIndex])
  @@index([workspaceId, channelId, scheduledAt])
  @@index([userId, status])
}

model EditorialOpportunity {
  id              String                       @id @default(cuid())
  userId          String
  workspaceId     String
  channelId       String
  opportunityKey  String
  title           String
  description     String                       @db.Text
  opportunityDate DateTime
  relevance       CalendarOpportunityRelevance @default(POSSIBLE)
  relevanceReason String                       @db.Text
  suggestedAngle  String?                      @db.Text
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel         Channel                      @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, channelId, opportunityKey])
  @@index([workspaceId, channelId, opportunityDate])
}

model AutomationJob {
  id                 String              @id @default(cuid())
  userId             String
  workspaceId        String
  channelId          String?
  storyProjectId     String?
  type               String
  status             AutomationJobStatus @default(QUEUED)
  payload            Json?
  idempotencyKey     String              @unique
  priority           Int                 @default(0)
  attempts           Int                 @default(0)
  maxAttempts        Int                 @default(5)
  runAfter           DateTime            @default(now())
  lockedBy           String?
  lockedAt           DateTime?
  leaseExpiresAt     DateTime?
  lastError          String?             @db.Text
  runBudgetUsd       Decimal             @default(10) @db.Decimal(12, 2)
  runCostBaselineUsd Decimal             @default(0) @db.Decimal(12, 6)
  completedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel            Channel?            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  storyProject       StoryProject?       @relation(fields: [storyProjectId], references: [id], onDelete: Cascade)

  @@index([status, runAfter, priority])
  @@index([workspaceId, status])
  @@index([storyProjectId, status])
  @@index([leaseExpiresAt])
}

model AdminSettings {
  id                           String   @id @default(cuid())
  openRouterGlobalKeyEncrypted String?  @db.Text
  defaultModel                 String   @default("anthropic/claude-sonnet-5")
  discoveryModel               String   @default("anthropic/claude-sonnet-5")
  dossierModel                 String   @default("anthropic/claude-sonnet-5")
  structureModel               String   @default("anthropic/claude-sonnet-5")
  draftingModel                String   @default("anthropic/claude-sonnet-5")
  critiqueModel                String   @default("openai/gpt-5.6-luna")
  rewriteModel                 String   @default("anthropic/claude-sonnet-5")
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}
